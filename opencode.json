{
  "$schema": "https://opencode.ai/config.json",
  "disabled_providers": [],
  "provider": {
    "uomi": {
      "name": "Uomi",
      "npm": "@ai-sdk/openai-compatible",
      "models": {
        "uomi": {
          "name": "Uomi"
        }
      },
      "options": {
        "baseURL": "https://openclaw.uomi.ai/v1"
      }
    }
  },
  "permission": {
    "skill": {
      "*": "allow"
    },
    "bash": {
      "*": "ask",
      "cat*": "allow",
      "ls*": "allow",
      "grep*": "allow",
      "mkdir*": "allow",
      "find*": "allow",
      "source*": "allow",
      "which*": "allow",
      "tail*": "allow",
      "sed*": "allow",
      "head*": "allow",
      "npm*": "allow",
      "npx*": "allow",
      "node*": "allow",
      "yarn*": "allow",
      "python*": "allow",
      "bundle*": "allow",
      "gem*": "allow",
      "pip*": "allow",
      "pip3*": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/**": "deny",
      "~/Workspace/**": "allow"
    }
  },
  "instructions": [
    "doc/*",
    "docs/*",
    "README.md",
    "AGENTS.md"
  ],
  "plugin": [
  ]
}